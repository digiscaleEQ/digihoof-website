---
/**
 * SEO Head Component
 *
 * Generates all meta tags for SEO, Open Graph, and Twitter Cards.
 * Used in BaseLayout for every page.
 */

import { buildSEO, type SEOProps } from '../../lib/seo';

interface Props extends SEOProps {
  ogTitle?: string;
  ogDescription?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
}

const seo = buildSEO(Astro.props, Astro.url.pathname);

// Allow explicit OG/Twitter overrides from frontmatter
const ogTitle = Astro.props.ogTitle || seo.title;
const ogDescription = Astro.props.ogDescription || seo.description;
const twitterTitle = Astro.props.twitterTitle || seo.title;
const twitterDescription = Astro.props.twitterDescription || seo.description;
const twitterImage = Astro.props.twitterImage || seo.ogImage;
---

<!-- Primary Meta -->
<title>{seo.title}</title>
<meta name="description" content={seo.description} />
{seo.noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={seo.canonical} />

<!-- Open Graph -->
<meta property="og:type" content={seo.ogType} />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={ogDescription} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:site_name" content={seo.siteName} />
<meta property="og:image" content={seo.ogImage} />
{seo.publishDate && <meta property="article:published_time" content={seo.publishDate} />}
{seo.updatedDate && <meta property="article:modified_time" content={seo.updatedDate} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={twitterTitle} />
<meta name="twitter:description" content={twitterDescription} />
<meta name="twitter:image" content={twitterImage} />
{seo.twitterHandle && <meta name="twitter:site" content={seo.twitterHandle} />}
