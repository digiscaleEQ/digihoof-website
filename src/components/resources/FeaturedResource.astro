---
/**
 * Featured Resource Component
 *
 * Prominent two-column card for the featured resource on the landing page.
 */

import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  excerpt: string;
  slug: string;
  publishDate: Date;
  category?: string;
  author?: string;
  heroImage?: string;
  heroImageAlt?: string;
  readingTime?: string;
}

const { title, excerpt, slug, publishDate, category, author, heroImage, heroImageAlt, readingTime } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="featured-resource">
  {heroImage ? (
    <img
      src={heroImage}
      alt={heroImageAlt || title}
      class="featured-resource__image"
      loading="eager"
    />
  ) : (
    <div class="featured-resource__image" style="background: var(--color-bg-alt); min-height: 320px;" />
  )}

  <div class="featured-resource__content">
    <div class="featured-resource__label">Featured</div>

    {category && <CategoryBadge category={category} />}

    <h2 class="featured-resource__title" style="margin-top: 12px;">
      <a href={`/resources/${slug}/`}>{title}</a>
    </h2>

    <p class="featured-resource__excerpt">{excerpt}</p>

    <div class="featured-resource__meta">
      <time datetime={publishDate.toISOString()}>{formattedDate}</time>
      {author && <span>· {author}</span>}
      {readingTime && <span>· {readingTime}</span>}
    </div>
  </div>
</article>
