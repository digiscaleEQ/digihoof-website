---
/**
 * Homepage
 *
 * Preserves the original DigiHoof homepage design exactly.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout includeOrgSchema={true}>

<section class="hero">
  <div class="container">
    <h1>Hoof Radiograph Reports. Standardized. Shareable.</h1>
    <p class="hero-subtitle">
      DigiHoof bridges veterinary imaging and farrier practice<br />
      with clear, repeatable hoof radiograph reports. Built for busy equine clinics.
    </p>
    <div class="hero-cta">
      <a href="https://app.digihoof.com/login" class="btn secondary">Clinic Login</a>
      <a href="/support" class="btn primary">Request Information</a>
    </div>
  </div>
</section>

<section class="split-section" id="why">
  <div class="container split">
    <div class="text">
      <h2>Built for Busy Equine Practices</h2>
      <p>
        When report generation is fast, it actually gets done.
        DigiHoof fits into high-volume imaging days
        so standardized hoof radiograph reports become part of the routine —
        not a time-consuming afterthought.
      </p>
    </div>
    <div class="image">
      <img src="/images/DIGIHOOFmarkup.png" alt="DigiHoof hoof radiograph report" loading="lazy" />
    </div>
  </div>
</section>

<section class="split-section alt">
  <div class="container split reverse">
    <div class="text">
      <h2>Bridge the Gap Between Vet and Farrier</h2>
      <p>
        Hoof radiographs only help when both the veterinarian and the farrier
        can clearly see and discuss the findings.
        DigiHoof presents measurements and overlays
        in a format farriers understand and trust —
        improving collaboration for the horse's benefit.
      </p>
    </div>
    <div class="image">
      <img src="/images/DIGIHOOFfarrier.png" alt="Veterinarian and farrier reviewing hoof radiograph" loading="lazy" />
    </div>
  </div>
</section>

<section class="split-section">
  <div class="container split">
    <div class="text">
      <h2>Repeatable Reports for Longitudinal Tracking</h2>
      <p>
        Consistent overlays and measurements across visits
        make real comparison possible.
        Track hoof balance changes, sole depth progression,
        and alignment over time with standardized reports
        that speak the same language every visit.
      </p>
    </div>
    <div class="image">
      <img src="/images/DIGIHOOFhoof.png" alt="Longitudinal hoof radiograph comparison" loading="lazy" />
    </div>
  </div>
</section>

<section class="difference">
  <div class="container">
    <h2>Why DigiHoof Is Different</h2>

    <div class="pillars">
      <div class="pillar">
        <h3>Fast Report Generation</h3>
        <p>
          Built for the pace of real practice.
          Generate professional hoof radiograph reports
          in minutes, not hours.
          When it's quick, it happens.
        </p>
      </div>

      <div class="pillar">
        <h3>AI-Assisted Standardization</h3>
        <p>
          Machine learning helps normalize landmark placement
          and measurements while preserving
          the veterinarian's clinical judgment.
        </p>
      </div>

      <div class="pillar">
        <h3>Mobile-Friendly Sharing</h3>
        <p>
          Farriers review reports on their phone or tablet.
          No PACS login required. No technical barriers.
          Just clear, actionable hoof data.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="cta-section migration-section">
  <div class="container">
    <h2>Designed for Everyday Hoof Work</h2>
    <p>
      Routine and follow-up hoof radiographs. Farrier review for trimming and shoeing decisions.
      Sport horses requiring longitudinal comparison. Clinics prioritizing clarity and communication.
    </p>
    <a href="/about" class="btn primary">Learn More About DigiHoof →</a>
  </div>
</section>

<section class="cta-section" id="resources">
  <div class="container">
    <h2>See How DigiHoof Works</h2>
    <p>
      Explore tutorials and feature demonstrations.
    </p>
    <a href="/tutorials" class="btn primary">View Tutorials</a>
  </div>
</section>

</BaseLayout>
