---
/**
 * Contact Page
 *
 * Business and support contact information.
 * Uses the same Turnstile-protected form as the support page.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Contact DigiHoof for support, business inquiries, or general questions about the hoof radiograph reporting platform."
>

<section class="contact-section">
  <div class="container">
    <h1>Contact Us</h1>
    <p>
      We'd like to hear from you. Whether you have a support question,
      business inquiry, or want to learn more about DigiHoof,
      reach out using the form below or contact us directly.
    </p>

    <div class="contact-details">
      <div class="contact-detail">
        <h3>Support</h3>
        <p><a href="mailto:support@digihoof.com">support@digihoof.com</a></p>
        <p class="contact-note">For technical questions, account issues, and billing inquiries.</p>
      </div>

      <div class="contact-detail">
        <h3>Business Inquiries</h3>
        <p><a href="mailto:support@digihoof.com">support@digihoof.com</a></p>
        <p class="contact-note">For partnerships, integrations, and general business questions.</p>
      </div>

      <div class="contact-detail">
        <h3>Company</h3>
        <p>DigiScan LLC</p>
        <p class="contact-note">DigiHoof is operated by DigiScan LLC, United States.</p>
      </div>
    </div>
  </div>
</section>

<section class="contact-section split-section alt">
  <div class="container">
    <h2>Send Us a Message</h2>

    <div id="contact-form-status" class="form-status"></div>

    <form class="contact-form" id="contact-page-form">
      <input type="text" name="name" placeholder="Your Name" required />
      <input type="email" name="email" placeholder="Your Email" required />
      <textarea name="message" placeholder="How can we help?" required></textarea>

      <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
      <div class="cf-turnstile" data-sitekey="0x4AAAAAACseCiqnb19bls8s" data-theme="dark"></div>

      <button type="submit">Send Message</button>
    </form>

    <p class="form-note">We typically respond within one business day.</p>
  </div>
</section>

</BaseLayout>

<style>
  .contact-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 32px;
    margin-top: 40px;
  }
  .contact-detail h3 {
    font-size: 1rem;
    margin-bottom: 8px;
    color: var(--color-text);
  }
  .contact-detail p {
    margin: 0;
    color: var(--color-text-body);
  }
  .contact-detail a {
    color: var(--color-primary);
  }
  .contact-detail a:hover {
    opacity: 0.8;
  }
  .contact-note {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 4px;
  }
</style>

<script is:inline>
document.getElementById('contact-page-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  const status = document.getElementById('contact-form-status');
  const btn = this.querySelector('button[type="submit"]');
  if (btn.disabled) return;
  btn.disabled = true;
  btn.textContent = 'Sending...';
  status.className = 'form-status';
  status.style.display = '';

  try {
    const payload = {
      name: this.name.value,
      email: this.email.value,
      message: this.message.value,
      source: "digihoof",
      type: "contact",
    };

    const turnstileInput = this.querySelector('[name="cf-turnstile-response"]');
    if (turnstileInput && turnstileInput.value) {
      payload.turnstile_token = turnstileInput.value;
    }

    const response = await fetch("https://api.digiscanlab.com/api/core/inquiries", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    if (response.ok) {
      status.textContent = 'Thanks \u2014 we\u2019ll be in touch shortly.';
      status.className = 'form-status success';
      status.style.display = '';
      this.reset();
      if (window.turnstile) turnstile.reset();
    } else {
      status.textContent = 'Something went wrong. Please try again.';
      status.className = 'form-status error';
      status.style.display = '';
    }
  } catch (err) {
    status.textContent = 'Something went wrong. Please try again.';
    status.className = 'form-status error';
    status.style.display = '';
  }
  btn.disabled = false;
  btn.textContent = 'Send Message';
});
</script>
