---
/**
 * Liability Disclaimer Page
 */

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Liability Disclaimer"
  description="DigiHoof liability disclaimer. DigiHoof is a reporting tool — all clinical decisions remain with the veterinarian and farrier."
>

<section class="split-section">
  <div class="container">
    <h1>Liability Disclaimer</h1>

    <p>
      DigiHoof provides hoof radiograph reporting, measurement, and sharing tools.
      The platform does not provide medical diagnoses, clinical advice,
      or farriery recommendations.
    </p>

    <p>
      All clinical decisions regarding hoof care, trimming, shoeing,
      and treatment remain the responsibility of the licensed
      veterinarian and qualified farrier reviewing the imaging data and reports.
    </p>

    <p>
      AI-assisted landmark detection and measurements are provided
      as decision-support tools only.
      The veterinarian retains full responsibility
      for verifying and approving all report contents.
    </p>

    <p>
      The company does not guarantee uninterrupted service availability
      and shall not be liable for damages resulting from service interruptions,
      user misuse, or third-party system failures.
    </p>
  </div>
</section>

</BaseLayout>
