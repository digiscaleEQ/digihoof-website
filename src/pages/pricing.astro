---
/**
 * Pricing Page
 *
 * Preserves the original DigiHoof pricing page design exactly.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Pricing"
  description="DigiHoof pricing. $15/month for unlimited hoof radiograph reports, AI-powered analysis, and client-ready PDFs."
>

<section class="pricing-header">
  <div class="container">
    <h1>Simple, Transparent Pricing</h1>
    <p>Create professional hoof radiograph reports in seconds.</p>
  </div>
</section>

<section>
  <div class="container">
    <div class="pricing-grid single-plan">

      <div class="pricing-card featured">
        <h2>DigiHoof</h2>
        <div class="pricing-price">$15 <span>/ month</span></div>
        <ul class="pricing-features">
          <li>Unlimited reports</li>
          <li>AI-powered hoof analysis</li>
          <li>Client-ready PDFs</li>
          <li>Mobile-friendly report sharing</li>
          <li>Longitudinal tracking across visits</li>
          <li>Cancel anytime — no long-term commitment</li>
        </ul>
        <a href="/support" class="btn primary">Get Started</a>
      </div>

    </div>
  </div>
</section>

</BaseLayout>
