---
/**
 * Support & Contact Page
 *
 * Preserves the original DigiHoof support page design exactly,
 * including the Turnstile-protected contact form.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Support & Contact"
  description="Contact DigiHoof support for onboarding, technical questions, billing inquiries, and assistance with hoof radiograph reporting."
>

<section class="contact-section">
  <div class="container">
    <h1>Support &amp; Contact</h1>
    <p>
      Have a question about DigiHoof or need help getting started?<br />
      Send us a message and we'll get back to you shortly.
    </p>
    <p class="support-email">
      You can also reach us directly at <a href="mailto:digihoof@digiscan.vet">digihoof@digiscan.vet</a>
    </p>

    <div id="form-status" class="form-status"></div>

    <form class="contact-form" id="contact-form">
      <input type="text" name="name" placeholder="Your Name" required />
      <input type="email" name="email" placeholder="Your Email" required />
      <textarea name="message" placeholder="How can we help?" required></textarea>

      <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
      <div class="cf-turnstile" data-sitekey="0x4AAAAAACseCiqnb19bls8s" data-theme="dark"></div>

      <button type="submit">Send Message</button>
    </form>

    <p class="form-note">We typically respond within one business day.</p>
  </div>
</section>

<section class="onboarding-section split-section alt">
  <div class="container">
    <h2>Billing &amp; Subscription Support</h2>
    <p>
      For questions about your subscription, invoices, or payment methods,
      contact us at <a href="mailto:digihoof@digiscan.vet">digihoof@digiscan.vet</a>.
    </p>
    <ul>
      <li>Subscription plan changes and cancellations</li>
      <li>Invoice and payment history</li>
      <li>Payment method updates</li>
      <li>Billing disputes or charge inquiries</li>
    </ul>
    <p>
      Subscriptions are billed by DigiScan LLC. For more information, visit our
      <a href="/billing">billing information page</a>.
    </p>
  </div>
</section>

<section class="onboarding-section split-section">
  <div class="container">
    <h2>Onboarding Assistance</h2>
    <p>
      Getting started with DigiHoof is straightforward.
      Our team provides onboarding support to help your practice
      integrate hoof radiograph reporting into your existing workflow.
    </p>
    <ul>
      <li>Account setup and configuration</li>
      <li>Workflow integration guidance for your practice</li>
      <li>Training on report generation and sharing</li>
      <li>Best practices for farrier collaboration</li>
    </ul>
  </div>
</section>

<section class="onboarding-section split-section alt">
  <div class="container">
    <h2>Farrier Access Support</h2>
    <p>
      DigiHoof is designed so farriers can view shared reports
      without needing a PACS login or specialized software.
      If farriers working with your clinic need help accessing shared reports,
      our team can assist.
    </p>
  </div>
</section>

<section class="onboarding-section split-section">
  <div class="container">
    <h2>Frequently Asked Questions</h2>

    <div class="faq-item">
      <h3>What browsers are supported?</h3>
      <p>
        DigiHoof works best on modern browsers including Chrome, Safari, Firefox, and Edge.
        We recommend using the latest version of your browser for the best experience.
      </p>
    </div>

    <div class="faq-item">
      <h3>What image formats can I upload?</h3>
      <p>
        DigiHoof supports standard radiograph image formats including DICOM, JPEG, and PNG.
      </p>
    </div>

    <div class="faq-item">
      <h3>How do I cancel my subscription?</h3>
      <p>
        You can cancel your subscription at any time by contacting us at
        <a href="mailto:digihoof@digiscan.vet">digihoof@digiscan.vet</a>.
        Your access will continue through the end of the current billing period.
      </p>
    </div>

    <div class="faq-item">
      <h3>How do farriers view shared reports?</h3>
      <p>
        Reports can be shared via a secure link that farriers can open in any browser —
        no login or special software required.
      </p>
    </div>

    <div class="faq-item">
      <h3>Who do I contact for billing issues?</h3>
      <p>
        For any billing questions, email
        <a href="mailto:digihoof@digiscan.vet">digihoof@digiscan.vet</a>.
        We'll respond within one business day.
      </p>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .support-email {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-top: -8px;
  }
  .support-email a {
    color: var(--color-primary);
  }
  .support-email a:hover {
    opacity: 0.8;
  }
  .faq-item {
    margin-bottom: 28px;
  }
  .faq-item h3 {
    font-size: 1.05rem;
    margin-bottom: 6px;
    color: var(--color-text);
  }
  .faq-item p {
    color: var(--color-text-body);
    margin-top: 0;
  }
  .faq-item a {
    color: var(--color-primary);
  }
</style>

<script is:inline>
document.getElementById('contact-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  const status = document.getElementById('form-status');
  const btn = this.querySelector('button[type="submit"]');
  if (btn.disabled) return;
  btn.disabled = true;
  btn.textContent = 'Sending...';
  status.className = 'form-status';
  status.style.display = '';

  try {
    const payload = {
      name: this.name.value,
      email: this.email.value,
      message: this.message.value,
      source: "digihoof",
      type: "support",
    };

    const turnstileInput = this.querySelector('[name="cf-turnstile-response"]');
    if (turnstileInput && turnstileInput.value) {
      payload.turnstile_token = turnstileInput.value;
    }

    const response = await fetch("https://api.digiscanlab.com/api/core/inquiries", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    if (response.ok) {
      status.textContent = 'Thanks \u2014 we\u2019ll be in touch shortly.';
      status.className = 'form-status success';
      status.style.display = '';
      this.reset();
      if (window.turnstile) turnstile.reset();
    } else {
      status.textContent = 'Something went wrong. Please try again.';
      status.className = 'form-status error';
      status.style.display = '';
    }
  } catch (err) {
    status.textContent = 'Something went wrong. Please try again.';
    status.className = 'form-status error';
    status.style.display = '';
  }
  btn.disabled = false;
  btn.textContent = 'Send Message';
});
</script>
