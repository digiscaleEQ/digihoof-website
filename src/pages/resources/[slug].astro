---
/**
 * Resource Article Route
 *
 * Dynamic route that generates a static page for each resource
 * in the content collection. Uses ResourceArticleLayout for premium
 * article reading experience.
 */

import ResourceArticleLayout from '../../layouts/ResourceArticleLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const resources = await getCollection('resources', ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  return resources.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<ResourceArticleLayout entry={entry} />
